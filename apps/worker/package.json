{
  "name": "@canarygate/worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch --env-file=.env.local src/index.ts",
    "build": "tsup src/index.ts --format cjs --out-dir dist",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@canarygate/database": "workspace:^",
    "@canarygate/logger": "workspace:^",
    "@canarygate/messaging-utils": "workspace:^",
    "@canarygate/redis": "workspace:^",
    "bullmq": "^5.61.0",
    "fastify": "^5.8.4",
    "drizzle-orm": "^0.41.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.0.0",
    "@testcontainers/redis": "^10.0.0",
    "@types/node": "^20",
    "@vitest/coverage-v8": "^3.0.0",
    "ioredis-mock": "^8.9.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "5.9.2",
    "vitest": "^3.0.0"
  }
}

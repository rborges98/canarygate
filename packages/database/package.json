{
  "name": "@canarygate/database",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/client.js",
  "types": "./dist/client.d.ts",
  "exports": {
    "./client": {
      "import": "./dist/client.js",
      "require": "./dist/client.js",
      "types": "./dist/client.d.ts"
    },
    "./schema": {
      "import": "./dist/schema.js",
      "require": "./dist/schema.js",
      "types": "./dist/schema.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/client.ts src/schema/index.ts --format cjs --dts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.41.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "tsup": "^8.5.1",
    "typescript": "^5"
  }
}
